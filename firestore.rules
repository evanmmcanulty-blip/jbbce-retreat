rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() { return isSignedIn() && me().admin == true; }
    // Accountant (Chris) confirms house-fund payments; admins implicitly qualify
    function isAccountant() { return isSignedIn() && (me().admin == true || me().accountant == true); }
    // Pre-approval-feature accounts have no 'approved' field and are grandfathered in;
    // new signups are approved == false until an admin flips them
    function isApproved() { return isSignedIn() && me().approved != false; }
    function changesOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /users/{uid} {
      // Unapproved accounts can only read their own profile (to see their pending state)
      allow read: if request.auth.uid == uid || isApproved();
      // Signup: only the designated admin email may create itself with admin/approved: true
      allow create: if request.auth.uid == uid
        && (request.resource.data.admin != true || request.auth.token.email == 'bnwokocha@gmail.com')
        && (request.resource.data.approved != true || request.auth.token.email == 'bnwokocha@gmail.com')
        && request.resource.data.accountant != true;
      // Privilege fields only changeable by an admin (no self-escalation/approval)
      allow update: if isAdmin()
        || (request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['admin', 'accountant', 'approved']));
    }

    match /events/{id} {
      allow read: if isApproved();
      // Idea promotion creates events owned by the idea's author, so owner != creator is legit
      allow create: if isApproved();
      allow update: if isAdmin() || resource.data.owner == request.auth.uid
        || changesOnly(['rsvps', 'rsvpsByDay']);
      allow delete: if isAdmin() || resource.data.owner == request.auth.uid;
    }

    // Ideas are collaboratively editable by design ("anyone can refine")
    match /ideas/{id} {
      allow read, create, update: if isApproved();
      allow delete: if isAdmin() || resource.data.by == request.auth.uid;
    }

    match /meals/{id} {
      allow read: if isApproved();
      allow create: if isAdmin() || (isApproved() && request.resource.data.keys().hasOnly(['votes']));
      // Guests vote; only admin sets final plan & cooks
      allow update: if isAdmin() || changesOnly(['votes']);
    }

    match /receipts/{id} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.by == request.auth.uid;
      // Tagged people log their own payments; owner/admin edit everything else
      allow update: if isAdmin() || resource.data.by == request.auth.uid
        || changesOnly(['payments']);
      allow delete: if isAdmin() || resource.data.by == request.auth.uid;
    }

    match /bulletins/{id} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.by == request.auth.uid;
      allow update: if isAdmin() || resource.data.by == request.auth.uid
        || changesOnly(['gotIt']);
      allow delete: if isAdmin() || resource.data.by == request.auth.uid;
    }

    // Anyone can claim / mark purchased — that's the feature
    match /groceries/{id} {
      allow read, create, update: if isApproved();
      allow delete: if isAdmin() || resource.data.addedBy == request.auth.uid;
    }

    match /infoCustom/{id} {
      allow read, create: if isApproved();
      allow update: if isAdmin();
      allow delete: if isAdmin() || resource.data.by == request.auth.uid;
    }

    // payments/{uid}: guest logs what they sent; only accountant confirms receipt
    match /payments/{uid} {
      allow read: if isApproved();
      allow write: if isAccountant()
        || (request.auth.uid == uid
            && (resource == null
                ? !request.resource.data.keys().hasAny(['confirmed'])
                : !request.resource.data.diff(resource.data).affectedKeys().hasAny(['confirmed'])));
    }

    // config/house: admin. config/cost: accountant (incl. admin).
    match /config/{docId} {
      allow read: if isApproved();
      allow write: if docId == 'cost' ? isAccountant() : isAdmin();
    }
  }
}
